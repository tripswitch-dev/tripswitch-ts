{
  "name": "@tripswitch-dev/tripswitch-ts",
  "version": "0.1.1",
  "description": "Official TypeScript SDK for TripSwitch circuit breaker service",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./admin": {
      "import": {
        "types": "./dist/admin/index.d.ts",
        "default": "./dist/admin/index.js"
      },
      "require": {
        "types": "./dist/admin/index.d.cts",
        "default": "./dist/admin/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --dir tests/integration",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "tripswitch",
    "circuit-breaker",
    "resilience",
    "fault-tolerance"
  ],
  "license": "Apache-2.0",
  "author": "TripSwitch <oss@tripswitch.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/tripswitch-dev/tripswitch-ts.git"
  },
  "homepage": "https://github.com/tripswitch-dev/tripswitch-ts#readme",
  "bugs": {
    "url": "https://github.com/tripswitch-dev/tripswitch-ts/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "eventsource": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
