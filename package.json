{
  "name": "tripswitch-ts",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for TripSwitch circuit breaker service",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./admin": {
      "import": {
        "types": "./dist/admin/index.d.ts",
        "default": "./dist/admin/index.js"
      },
      "require": {
        "types": "./dist/admin/index.d.cts",
        "default": "./dist/admin/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "tripswitch",
    "circuit-breaker",
    "resilience",
    "fault-tolerance"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "eventsource": "^2.0.2"
  },
  "devDependencies": {
    "@types/eventsource": "^1.1.15",
    "@types/node": "^25.3.3",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
